      "isDeleted": false,
      "boundElements": null,
      "updated": 1772517336962,
      "link": null,
      "locked": false,
      "text": "1)make a queue, take the first node/root push is into the queue\n2)now push the left and right of the node into the queue and print the current node\n3)now take the next node in the queue as the root and check for left and right ...\n4)if left or right is empty leave it.\n5)if the tree is done, dequeue the whole queue and print it.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1)make a queue, take the first node/root push is into the queue\n2)now push the left and right of the node into the queue and print the current node\n3)now take the next node in the queue as the root and check for left and right ...\n4)if left or right is empty leave it.\n5)if the tree is done, dequeue the whole queue and print it.",
      "autoResize": true,
      "lineHeight": 1.25
    },
